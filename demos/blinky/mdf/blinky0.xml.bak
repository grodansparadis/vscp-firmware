<vscp>
<module>
<name>VSCP Blink</name>
<copyright>Grodans Paradis AB</copyright>
<level>0</level>
<model>A</model>
<version>0.0.01</version>
<changed>07/06/2026</changed>
<buffersize>0</buffersize>
<description lang="en">This is the simplest possible demo of a VSCP node. It can do one thing, light a led, blink a led, turn a led off. The blink frequency can be set.  It has a decsion matrix with some actions like turn on/off led is defined.</description>
<manufacturer>
<name>Grodans Paradis AB</name>
<address>
<street>Brattbergavägen 17</street>
<city>LOS</city>
<town>LOS</town>
<region>Hälsingland</region>
<postcode>82770</postcode>
<state>HA</state>
<country>Sweden</country>
</address>
</manufacturer>
<boot>
<algorithm>0</algorithm>
<blocksize>0</blocksize>
<blockcount>0</blockcount>
</boot>
<files>
</files>
<registers>
</registers>
<remotevars>
</remotevars>
<alarm>
</alarm>
<dmatrix level="1" start-page="255" start-offset="0" rowcnt="4" rowsize="8" >
<action name="NOOP" code="0" >
</action>
<action name="Enable blink" code="1" >
</action>
<action name="Disable blink" code="2" >
<param name="Rest state for LED" offset="0" min="0" max="1" >
<valuelist> 
<item name="Off" value="0" >
</item> 
<item name="On" value="1" >
</item> 
</valuelist> 
<description lang="en">Tell if the LED should be on or off after it has been stoped.</description>
</param>
</action>
<action name="Activate LED" code="3" >
</action>
<action name="Deactivate LED" code="4" >
</action>
<action name="LED Control" code="5" >
<param name="Enable" offset="0" min="0" max="2" >
<valuelist> 
<item name="Off" value="0" >
</item> 
<item name="On" value="1" >
</item> 
</valuelist> 
</param>
</action>
</dmatrix>
<events>
</events></module>
</vscp>
