      {
        "name": "Status",
        "page": 0,
        "offset": 2,
        "span": 1,
        "width": 8,
        "access": "rw",
        "type": "std",
        "default": "UNDEF",
        "min": 0,
        "max": 255,
        "fgcolor": "0x0",
        "bgcolor": "0xffffff",
        "description": {
          "en": "Status of the node. This indicates the current state of the LED, 0=ON, 1=OFF.",
          "se": "Status för noden. Detta indikerar det aktuella tillståndet för LED, 0=ON, 1=OFF.",
          "no": "Status for noden. Dette indikerer den nåværende tilstanden til LED, 0=ON, 1=OFF.",
          "dk": "Status for noden. Dette indikerer den aktuelle tilstand for LED, 0=ON, 1=OFF.",
          "de": "Status des Knotens. Dies zeigt den aktuellen Zustand der LED an, 0=ON, 1=OFF.",
          "fr": "Statut du nœud. Cela indique l'état actuel de la LED, 0=ON, 1=OFF.",
          "es": "Estado del nodo. Esto indica el estado actual del LED, 0=ON, 1=OFF.",
          "it": "Stato del nodo. Questo indica lo stato attuale del LED, 0=ON, 1=OFF.",
          "ru": "Статус узла. Это указывает текущее состояние светодиода, 0=ВКЛ, 1=ВЫКЛ.",
          "fi": "Solmun tila. Tämä osoittaa LEDin nykyisen tilan, 0=ON, 1=OFF.",
          "zh": "节点的状态。这表示LED的当前状态，0 = ON，1 = OFF。",
          "ja": "ノードのステータス。これはLEDの現在の状態を示します。0 = ON、1 = OFF。",
          "pt": "Status do nó. Isso indica o estado atual do LED, 0 = ON, 1 = OFF.",
          "ar": "حالة العقدة. هذا يشير إلى الحالة الحالية للLED، 0 = ON، 1 = OFF.",
          "sk": "Stav uzlu. To ukazuje aktuální stav LED, 0 = ON, 1 = OFF.",
          "hu": "A csomópont állapota. Ez jelzi a LED aktuális állapotát, 0=ON, 1=OFF.",
          "kr": "노드의 상태입니다. 이것은 LED의 현재 상태를 나타냅니다. 0=ON, 1=OFF."
        },
        "infourl": {
          "en": "https://github.com/grodansparadis/vscp/wiki/blinky-info-url-register-2"
        },
        "bit": [
          {
            "name": "LED active",
            "pos": 1,
            "width": 1,
            "default": 1,
            "access": "rw",
            "description": {
              "en": "Status bit telling that the LED is active. 0=LED is off, 1=LED is on. If written to, the LED will be turned on or off depending on the value written. If the LED is enabled in the control register, the LED will be turned on or off depending on the value written.",
              "se": "Statusbit som anger att LED är aktiv. 0=LED är av, 1=LED är på. Om den skrivs till, kommer LED att tändas eller slockna beroende på det skrivna värdet. Om LED är aktiverad i kontrollregistret, kommer LED att tändas eller slockna beroende på det skrivna värdet.",
              "no": "Statusbit som indikerer at LED er aktiv. 0=LED er av, 1=LED er på. Hvis det skrives til, vil LED slås på eller av avhengig av verdien som skrives. Hvis LED er aktivert i kontrollregisteret, vil LED slås på eller av avhengig av verdien som skrives.",
              "dk": "Statusbit, der angiver, at LED er aktiv. 0=LED er slukket, 1=LED er tændt. Hvis der skrives til den, vil LED'en blive tændt eller slukket afhængigt af den skrevne værdi. Hvis LED er aktiveret i kontrolregisteret, vil LED'en blive tændt eller slukket afhængigt af den skrevne værdi.",
              "de": "Statusbit, das angibt, dass die LED aktiv ist. 0=LED ist aus, 1=LED ist an. Wenn darauf geschrieben wird, wird die LED je nach geschriebenem Wert ein- oder ausgeschaltet. Wenn die LED im Steuerregister aktiviert ist, wird die LED je nach geschriebenem Wert ein- oder ausgeschaltet.",
              "fr": "Bit d'état indiquant que la LED est active. 0=LED éteinte, 1=LED allumée. En cas d'écriture, la LED sera allumée ou éteinte selon la valeur écrite. Si la LED est activée dans le registre de contrôle, elle sera allumée ou éteinte selon la valeur écrite.",
              "es": "Bit de estado que indica que el LED está activo. 0=LED apagado, 1=LED encendido. Si se escribe, el LED se encenderá o apagará según el valor escrito. Si el LED está habilitado en el registro de control, el LED se encenderá o apagará según el valor escrito.",
              "it": "Bit di stato che indica che il LED è attivo. 0=LED spento, 1=LED acceso. Se scritto, il LED sarà acceso o spento a seconda del valore scritto. Se il LED è abilitato nel registro di controllo, il LED sarà acceso o spento a seconda del valore scritto.",
              "ru": "Бит состояния, указывающий, что светодиод активен. 0=LED выключен, 1=LED включен. При записи светодиод будет включён или выключён в зависимости от записанного значения. Если светодиод включён в регистре управления, он будет включён или выключён в зависимости от записанного значения.",
              "fi": "Tilabitti, joka kertoo, että LED on aktiivinen. 0=LED pois päältä, 1=LED päällä. Jos siihen kirjoitetaan, LED sytytetään tai sammutetaan kirjoitetun arvon mukaan. Jos LED on käytössä ohjausrekisterissä, LED sytytetään tai sammutetaan kirjoitetun arvon mukaan.",
              "zh": "状态位，指示LED是否处于活动状态。0=LED关闭，1=LED开启。写入时，LED将根据写入的值打开或关闭。如果控制寄存器中启用了LED，则LED将根据写入的值打开或关闭。",
              "ja": "LEDがアクティブであることを示すステータスビット。0=LEDオフ、1=LEDオン。書き込まれると、書き込まれた値に応じてLEDがオンまたはオフになります。制御レジスタでLEDが有効な場合、書き込まれた値に応じてLEDがオンまたはオフになります。",
              "pt": "Bit de status indicando que o LED está ativo. 0=LED desligado, 1=LED ligado. Se escrito, o LED será ligado ou desligado dependendo do valor escrito. Se o LED estiver habilitado no registrador de controle, o LED será ligado ou desligado dependendo do valor escrito.",
              "ar": "بت الحالة الذي يشير إلى أن LED نشط. 0=LED مغلق، 1=LED مفتوح. عند الكتابة إليه، سيتم تشغيل أو إيقاف تشغيل LED بناءً على القيمة المكتوبة. إذا كان LED ممكّناً في سجل التحكم، فسيتم تشغيل أو إيقاف تشغيل LED بناءً على القيمة المكتوبة.",
              "sk": "Stavový bit, ktorý indikuje, že LED je aktívny. 0=LED vypnutý, 1=LED zapnutý. Ak sa doň zapisuje, LED sa zapne alebo vypne v závislosti od zapísanej hodnoty. Ak je LED povolený v riadiacom registri, LED sa zapne alebo vypne v závislosti od zapísanej hodnoty.",
              "hu": "Állapotbit, amely jelzi, hogy a LED aktív. 0=LED ki, 1=LED be. Ha írják, a LED be- vagy kikapcsol az írt értéktől függően. Ha a LED engedélyezve van a vezérlőregiszterben, a LED be- vagy kikapcsol az írt értéktől függően.",
              "kr": "상태 비트로 LED가 활성 상태인지 나타냅니다. 0=LED 꺼짐, 1=LED 켜짐. 쓰여지면 쓰여진 값에 따라 LED가 켜지거나 꺼집니다. LED가 제어 레지스터에서 활성화된 경우, 쓰여진 값에 따라 LED가 켜지거나 꺼집니다."
            }
          },
          {
            "name": "Button active",
            "pos": 0,
            "width": 1,
            "default": 1,
            "access": "rw",
            "description": {
              "en": "Status bit that tell that button is active. 0=Button is not active, 1=Button is active.",
              "se": "Statusbit som anger att knappen är aktiv. 0=Knappen är inte aktiv, 1=Knappen är aktiv.",
              "no": "Statusbit som indikerer at knappen er aktiv. 0=Knappen er ikke aktiv, 1=Knappen er aktiv.",
              "dk": "Statusbit, der angiver, at knappen er aktiv. 0=Knappen er ikke aktiv, 1=Knappen er aktiv.",
              "de": "Statusbit, das angibt, dass die Taste aktiv ist. 0=Taste ist nicht aktiv, 1=Taste ist aktiv.",
              "fr": "Bit d'état indiquant que le bouton est actif. 0=Le bouton n'est pas actif, 1=Le bouton est actif.",
              "es": "Bit de estado que indica que el botón está activo. 0=El botón no está activo, 1=El botón está activo.",
              "it": "Bit di stato che indica che il pulsante è attivo. 0=Il pulsante non è attivo, 1=Il pulsante è attivo.",
              "ru": "Бит состояния, указывающий, что кнопка активна. 0=Кнопка не активна, 1=Кнопка активна.",
              "fi": "Tilabitti, joka kertoo, että painike on aktiivinen. 0=Painike ei ole aktiivinen, 1=Painike on aktiivinen.",
              "zh": "状态位，指示按钮是否处于活动状态。0=按钮未激活，1=按钮已激活。",
              "ja": "ボタンがアクティブであることを示すステータスビット。0=ボタンはアクティブではない、1=ボタンはアクティブです。",
              "pt": "Bit de status que indica que o botão está ativo. 0=O botão não está ativo, 1=O botão está ativo.",
              "ar": "بت الحالة الذي يشير إلى أن الزر نشط. 0=الزر غير نشط، 1=الزر نشط.",
              "sk": "Stavový bit, ktorý indikuje, že tlačidlo je aktívne. 0=Tlačidlo nie je aktívne, 1=Tlačidlo je aktívne.",
              "hu": "Állapotbit, amely jelzi, hogy a gomb aktív. 0=A gomb nem aktív, 1=A gomb aktív.",
              "kr": "상태 비트로 버튼이 활성 상태인지 나타냅니다. 0=버튼 비활성, 1=버튼 활성"
            }
          }
        ]
      },
      {
        "name": "Control",
        "page": 0,
