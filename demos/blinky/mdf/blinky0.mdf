        "bit": [
          {
            "name": "Enable LED",
            "pos": 7,
            "width": 1,
            "default": 1,
            "access": "rw",
            "description": {
              "en": "Set bit to enable control of the LED. Clear bit to disable control of the LED.",
              "se": "Sätt bit för att aktivera kontroll av LED. Rensa bit för att inaktivera kontroll av LED.",
              "no": "Sett bit for å aktivere kontroll av LED. Rens bit for å deaktivere kontroll av LED.",
              "dk": "Sæt bit for at aktivere kontrol af LED. Rens bit for at deaktivere kontrol af LED.",
              "de": "Setzen Sie das Bit, um die Steuerung der LED zu aktivieren. Löschen Sie das Bit, um die Steuerung der LED zu deaktivieren.",
              "fr": "Définissez le bit pour activer le contrôle de la LED. Effacez le bit pour désactiver le contrôle de la LED.",
              "es": "Establezca el bit para habilitar el control del LED. Borre el bit para deshabilitar el control del LED.",
              "it": "Imposta il bit per abilitare il controllo del LED. Cancella il bit per disabilitare il controllo del LED.",
              "ru": "Установите бит для включения управления светодиодом. Очистите бит для отключения управления светодиодом.",
              "fi": "Aseta bitti, jotta voit ohjata LEDiä. Tyhjennä bitti, jotta et voi ohjata LEDiä.",
              "zh": "设置位以启用LED的控制。清除位以禁用LED的控制。",
              "ja": "LEDの制御を有効にするにはビットを設定します。LEDの制御を無効にするにはビットをクリアします。",
              "pt": "Defina o bit para habilitar o controle do LED. Limpe o bit para desabilitar o controle do LED.",
              "ar": "قم بتعيين البت لتمكين التحكم في LED. امسح البت لتعطيل التحكم في LED.",
              "sk": "Nastavte bit pro povolení ovládání LED. Vymažte bit pro zakázání ovládání LED.",
              "hu": "Állítsa be a bitet az LED vezérlésének engedélyezéséhez. Törölje a bitet az LED vezérlésének letiltásához.",
              "kr": "비트를 설정하여 LED 제어를 활성화합니다. 비트를 지워 LED 제어를 비활성화합니다."
            },
            "infourl": {
              "en": "https://github.com/grodansparadis/vscp/wiki/blinky-info-url-register-3"
            }
          },
          {
            "name": "Enable Button",
            "pos": 6,
            "width": 1,
            "default": 1,
            "access": "rw",
            "description": {
              "en": "Enable button, will send turn-on/turn-off events when button is pressed.",
              "se": "Aktivera brytare, kommer att skicka på/av händelser när knappen trycks.",
              "es": "Habilitar el botón, enviará eventos de encendido/apagado cuando se presione el botón.",
              "ru": "Включить кнопку, будет отправлять события включения/выключения при нажатии кнопки.",
              "fi": "Ota painike käyttöön, lähettää päälle/pois -tapahtumia, kun painiketta painetaan.",
              "zh": "启用按钮，当按钮被按下时将发送开/关事件。",
              "ja": "ボタンを有効にすると、ボタンが押されたときにオン/オフイベントが送信されます。",
              "pt": "Habilitar botão, enviará eventos de ligar/desligar quando o botão for pressionado.",
              "ar": "تمكين الزر، سيرسل أحداث التشغيل/الإيقاف عند الضغط على الزر.",
              "sk": "Povoliť tlačidlo, bude odosielať udalosti zapnutia/vypnutia, keď sa tlačidlo stlačí.",
              "no": "Aktiver knapp, vil sende på/av hendelser når knappen trykkes.",
              "dk": "Aktiver knap, vil sende tænd/sluk begivenheder, når knappen trykkes.",
              "de": "Aktivieren Sie die Taste, es werden Ein/Aus-Ereignisse gesendet, wenn die Taste gedrückt wird.",
              "fr": "Activer le bouton, enverra des événements on/off lorsque le bouton est pressé.",
              "it": "Abilitare il pulsante, invierà eventi on/off quando il pulsante viene premuto.",
